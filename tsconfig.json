{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "lib": [
      "ES2019"
    ],
    "moduleResolution": "bundler",
    "target": "ES2019",
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "extends": "expo/tsconfig.base"
}
